{
    "buildCommand": "pnpm install && pnpm run build",
      "outputDirectory": "dist/public",
        "framework": null,
          "functions": {
              "api/index.ts": {
                    "runtime": "@vercel/node@3.0.0",
                          "maxDuration": 10
                              }
                                },
                                  "rewrites": [
                                      { "source": "/api/(.*)", "destination": "/api/index.ts" },
                                          { "source": "/(.*)", "destination": "/index.html" }
                                            ]
                                            }
}