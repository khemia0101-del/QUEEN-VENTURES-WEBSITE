# Database (MySQL)
DATABASE_URL=mysql://user:password@host:3306/queen_ventures

# JWT Secret for session cookies
JWT_SECRET=your-secret-key-change-in-production

# Stripe (for donations)
STRIPE_SECRET_KEY=sk_test_your_stripe_key
